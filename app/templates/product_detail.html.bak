<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ product.name }} Profile | AXIS</title>
    <script src="/static/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="/static/css/font-awesome.min.css">
</head>
<body class="bg-slate-50 min-h-screen font-sans text-slate-900 antialiased">
    <div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
        
        <!-- TOP ACTIONS & BREADCRUMB -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
                <div class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">
                    <span>Inventory</span>
                    <i class="fas fa-chevron-right text-[8px]"></i>
                    <span>{{ product.category }}</span>
                    <i class="fas fa-chevron-right text-[8px]"></i>
                    <span class="text-slate-600">{{ product.sku }}</span>
                </div>
                <h1 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight uppercase">{{ product.name }}</h1>
            </div>
            <div class="flex items-center gap-2 w-full sm:w-auto">
                <a href="/inventory" class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-2 bg-white border border-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-bold uppercase text-xs shadow-sm hover:bg-slate-50 transition">
                    <i class="fas fa-arrow-left"></i> Inventory
                </a>
                <button onclick="openProductModal('edit')" class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-2 bg-indigo-600 text-white px-4 py-2.5 rounded-xl font-bold uppercase text-xs shadow-md shadow-indigo-200 hover:bg-indigo-700 transition">
                    <i class="fas fa-edit"></i> Edit / Restock Asset
                </button>
            </div>
        </div>

        <!-- DUKAN REAL-TIME ANALYTICS METRICS -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            
            <!-- 1. TOTAL QUANTITY AVAILABLE -->
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Dukan Me Available Stock</div>
                    <div class="text-3xl font-black text-slate-800">{{ product.stock }} <span class="text-sm font-bold text-slate-400 uppercase">Units</span></div>
                </div>
                <div class="mt-3">
                    <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                        {% if product.stock == 0 %}
                            <div class="bg-rose-500 h-full w-0"></div>
                        {% elif product.stock < 10 %}
                            <div class="bg-amber-500 h-full w-1/3"></div>
                        {% else %}
                            <div class="bg-emerald-500 h-full w-full"></div>
                        {% endif %}
                    </div>
                    <div class="flex justify-between items-center text-[10px] font-black uppercase tracking-wide mt-1.5">
                        <span>Status:</span>
                        {% if product.stock == 0 %}
                            <span class="text-rose-600 bg-rose-50 px-1.5 py-0.5 rounded font-black">Stock Khatam</span>
                        {% elif product.stock < 10 %}
                            <span class="text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded font-black">Low Stock</span>
                        {% else %}
                            <span class="text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded font-black">In Stock</span>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- 2. TOTAL BUYING COST (TOTAL INVESTMENT) -->
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Kul Kharid Lagat (Total Buying Cost)</div>
                    <div class="text-2xl font-black text-slate-800">Rs. {{ (product.stock * product.purchase_price) | round(2) }}</div>
                    <p class="text-[10px] text-slate-400 mt-1">Maujooda stock ki buying keemat</p>
                </div>
                <div class="text-[11px] font-medium text-slate-500 mt-4 border-t border-slate-100 pt-2 flex justify-between">
                    <span>Per Item Buying:</span>
                    <span class="font-bold text-slate-700">Rs. {{ product.purchase_price }}</span>
                </div>
            </div>

            <!-- 3. SELLING PRICE & BREAKDOWN -->
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Expected Retail Value</div>
                    <div class="text-2xl font-black text-slate-800">Rs. {{ (product.stock * product.selling_price) | round(2) }}</div>
                    <p class="text-[10px] text-slate-400 mt-1">Poora stock bikne par total value</p>
                </div>
                <div class="text-[11px] font-medium text-slate-500 mt-4 border-t border-slate-100 pt-2 flex justify-between">
                    <span>Per Item Selling:</span>
                    <span class="font-bold text-slate-700">Rs. {{ product.selling_price }}</span>
                </div>
            </div>

            <!-- 4. GROSS UNITS SOLD -->
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Kitne Items Sell Ho Chuke Hain</div>
                    <div class="text-3xl font-black text-indigo-600">{{ analytics.total_units or 0 }} <span class="text-xs text-slate-400 font-bold uppercase">Sold</span></div>
                </div>
                <div class="text-[11px] font-medium text-slate-500 mt-4 border-t border-slate-100 pt-2 flex justify-between">
                    <span>Total Invoices Issued:</span>
                    <span class="font-bold text-slate-700">{{ analytics.sale_count or 0 }} Bills</span>
                </div>
            </div>

        </div>

        <!-- MAIN ANALYTICAL SPLIT FRAME -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            
            <!-- LEFT COLUMN: SYSTEM DATA IDENTITY -->
            <div class="bg-white rounded-3xl p-6 border border-slate-200 shadow-sm space-y-6">
                <div>
                    <h3 class="text-xs font-black uppercase tracking-wider text-slate-400 mb-4">Product Identity Blueprint</h3>
                    <div class="divide-y divide-slate-100 text-sm">
                        <div class="py-2.5 flex justify-between"><span class="text-slate-500">Category Tag</span> <span class="font-bold text-slate-800">{{ product.category }}</span></div>
                        <div class="py-2.5 flex justify-between"><span class="text-slate-500">Class Target</span> <span class="font-bold text-slate-800">{{ product.student_class or 'All Classes' }}</span></div>
                        <div class="py-2.5 flex justify-between"><span class="text-slate-500">Subject/Variant</span> <span class="font-bold text-slate-800">{{ product.subject or 'General' }}</span></div>
                        <div class="py-2.5 flex justify-between"><span class="text-slate-500">Stock Serial (SKU)</span> <span class="font-mono bg-slate-50 px-2 py-0.5 rounded text-xs text-slate-600 font-bold border">{{ product.sku }}</span></div>
                        <div class="py-2.5 flex justify-between"><span class="text-slate-500">System Barcode</span> <span class="font-mono text-slate-600 text-xs font-bold">{{ product.barcode or 'None Generated' }}</span></div>
                        {% if product.variation %}
                        <div class="py-2.5 flex justify-between"><span class="text-slate-500">Attributes Matrix</span> <span class="font-medium text-slate-700">{{ product.variation }}</span></div>
                        {% endif %}
                    </div>
                </div>

                <div class="bg-slate-50 rounded-2xl p-4 border border-slate-200/60">
                    <h4 class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2">Dukandaar Recommendation</h4>
                    <p class="text-xs text-slate-600 leading-relaxed">
                        {% if product.stock < 10 %}
                            Is item ka stock tezi se khatam ho raha hai. Restock or delta check jaldi apply karein.
                        {% else %}
                            Stock aur credit health check maintain rakhein taake cash flow balance rhey.
                        {% endif %}
                    </p>
                </div>
            </div>

            <!-- RIGHT TWO COLUMNS: LIVE PERFORMANCE & CREDIT METRICS -->
            <div class="lg:col-span-2 bg-white rounded-3xl p-6 border border-slate-200 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="flex justify-between items-center border-b border-slate-100 pb-4 mb-4">
                        <div>
                            <h3 class="text-sm font-black uppercase tracking-wider text-slate-800">Business Sales & Credit Analytics</h3>
                            <p class="text-xs text-slate-400">Total collection status, cleared profit, and pending credit summary.</p>
                        </div>
                        <span class="px-2.5 py-1 rounded-md bg-indigo-50 border border-indigo-100 text-[10px] font-black tracking-wide text-indigo-600 uppercase">Live Metrics</span>
                    </div>

                    <!-- REVENUE, PROFIT, AND UDHAAR GRID -->
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div class="bg-gradient-to-br from-slate-50 to-slate-100/50 p-4 rounded-2xl border border-slate-200/60">
                            <span class="text-[10px] font-black uppercase tracking-wider text-slate-400 block mb-1">Total Net Revenue</span>
                            <span class="text-2xl font-black text-slate-800">Rs. {{ analytics.total_revenue | round(2) }}</span>
                        </div>
                        <div class="bg-gradient-to-br from-emerald-50/30 to-emerald-50 p-4 rounded-2xl border border-emerald-200/60">
                            <span class="text-[10px] font-black uppercase tracking-wider text-emerald-600 block mb-1">Net Received Profit</span>
                            <span class="text-2xl font-black text-emerald-800">Rs. {{ analytics.profit | round(2) }}</span>
                        </div>
                        
                        <!-- LIVE CREDIT / PENDING CARD (INTERACTIVE FILTER TOGGLE) -->
                        {% set credit_count = namespace(value=0) %}
                        {% set credit_amount = namespace(value=0) %}
                        {% for sale in sales %}
                            {% if sale.payment_status != 'Paid' %}
                                {% set credit_count.value = credit_count.value + 1 %}
                                {% set credit_amount.value = credit_amount.value + (sale.price | float) %}
                            {% endif %}
                        {% endfor %}
                        <div onclick="toggleCreditFilter()" class="bg-gradient-to-br from-rose-50 to-rose-100/60 p-4 rounded-2xl border border-rose-200/70 cursor-pointer hover:shadow-md transition group relative">
                            <span class="text-[10px] font-black uppercase tracking-wider text-rose-600 block mb-1">Pending Udhaar (Credit)</span>
                            <span class="text-2xl font-black text-rose-700">Rs. {{ credit_amount.value | round(2) }}</span>
                            <div class="flex justify-between items-center mt-2 text-[10px] font-bold text-rose-600">
                                <span>{{ credit_count.value }} Accounts Pending</span>
                                <span class="bg-rose-700 text-white text-[9px] px-1.5 py-0.5 rounded uppercase font-black tracking-wide group-hover:bg-rose-800">Filter</span>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                        <div class="border border-slate-100 rounded-xl p-3.5 flex justify-between items-center text-xs">
                            <span class="text-slate-500 font-medium">Last Sold Out Timestamp:</span>
                            <span class="font-bold text-slate-700">{{ analytics.last_sold or 'No transactions logged' }}</span>
                        </div>
                        <div id="filterAlertBar" class="hidden border border-amber-200 bg-amber-50 rounded-xl p-3 flex justify-between items-center text-xs text-amber-800">
                            <span class="font-medium"><i class="fas fa-filter mr-1"></i> Showing only **Pending/Credit** records</span>
                            <button onclick="toggleCreditFilter()" class="bg-amber-200 hover:bg-amber-300 font-black px-2 py-0.5 rounded text-[10px] uppercase">Clear</button>
                        </div>
                    </div>
                </div>

                <div class="mt-6 pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-2 text-xs">
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full bg-indigo-500 animate-pulse"></span>
                        <span class="text-slate-500 font-medium">Dukan Operations Status:</span>
                        {% if credit_amount.value > 5000 %}
                            <span class="font-black text-rose-600 uppercase">⚠️ High Outstanding Balance</span>
                        {% else %}
                            <span class="font-black text-emerald-600 uppercase">✅ Recovery Control Stable</span>
                        {% endif %}
                    </div>
                </div>
            </div>

        </div>

        <!-- TRANSACTIONS HISTORY ARCHIVE -->
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 border-b border-slate-100 pb-4">
                <div>
                    <h2 class="font-black text-xl text-slate-900 uppercase tracking-tight">Product Sales Feed</h2>
                    <p class="text-xs text-slate-500 mt-0.5">Real-time ledger of purchases. Click the red card above to filter out credit accounts.</p>
                </div>
                <div class="text-[10px] uppercase font-black tracking-wider text-slate-400 bg-slate-50 px-2.5 py-1 rounded-md border">Audit Ready Log</div>
            </div>

            {% if sales %}
            <div class="overflow-x-auto">
                <table id="salesTable" class="min-w-full text-left text-sm text-slate-700">
                    <thead>
                        <tr class="bg-slate-50/70 text-slate-400 uppercase text-[9px] font-black tracking-wider border-b border-slate-200">
                            <th class="p-4">Receipt Identifier</th>
                            <th class="p-4">Student / Customer Profile</th>
                            <th class="p-4 text-center">Quantity</th>
                            <th class="p-4">Final Settled Price</th>
                            <th class="p-4">Clearance Status</th>
                            <th class="p-4 text-right">Transaction Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for sale in sales %}
                        <tr class="sales-row hover:bg-slate-50/80 transition-colors" data-status="{{ sale.payment_status }}">
                            <td class="p-4 font-mono font-bold text-slate-900 text-xs">{{ sale.receipt_number }}</td>
                            <td class="p-4">
                                <div class="font-bold text-slate-800">{{ sale.student_name or 'Walk-in Customer' }}</div>
                                <div class="text-[10px] font-medium text-slate-400 flex items-center gap-1.5 mt-0.5">
                                    <i class="fas fa-phone text-[8px]"></i> {{ sale.phone_no or 'No Phone Record' }}
                                </div>
                            </td>
                            <td class="p-4 font-black text-center text-slate-800">{{ sale.qty }}</td>
                            <td class="p-4 font-semibold text-slate-900">Rs. {{ sale.price }}</td>
                            <td class="p-4">
                                <span class="payment-badge px-2 py-0.5 rounded-md text-[10px] font-black uppercase tracking-wider {{ 'bg-emerald-50 text-emerald-700 border border-emerald-200/50' if sale.payment_status == 'Paid' else 'bg-rose-50 text-rose-700 border border-rose-200/50' }}">
                                    {{ sale.payment_status }}
                                </span>
                            </td>
                            <td class="p-4 text-right text-slate-500 text-xs font-medium">{{ sale.timestamp }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="py-16 text-center">
                <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-3 text-slate-400">
                    <i class="fas fa-folder-open text-base"></i>
                </div>
                <div class="text-xs font-black text-slate-400 uppercase tracking-wider">No Sales Transactions Logged Yet</div>
            </div>
            {% endif %}
        </div>

    </div>

    <!-- DYNAMIC SMART ADD/EDIT DUKANDAAR MODAL MODULATOR -->
    <div id="productModal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 z-50 animate-fade-in">
        <div class="bg-white rounded-3xl border border-slate-200 shadow-2xl max-w-lg w-full overflow-hidden transform transition-all scale-100">
            <div class="bg-slate-50 border-b border-slate-100 p-5 flex justify-between items-center">
                <div>
                    <h3 id="modalTitle" class="text-sm font-black uppercase tracking-wider text-slate-800">Update / Restock Existing Item Element</h3>
                </div>
                <button onclick="closeProductModal()" class="w-8 h-8 rounded-full bg-white border border-slate-200 text-slate-400 hover:text-slate-600 flex items-center justify-center shadow-sm transition">
                    <i class="fas fa-times text-xs"></i>
                </button>
            </div>

            <form id="productForm" onsubmit="handleFormSubmission(event)" class="p-6 space-y-4">
                <input type="hidden" id="formMode" value="edit">
                <input type="hidden" id="formProdId" value="{{ product.id }}">

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Category Element</label>
                        <select id="prodCat" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs font-bold text-slate-700 focus:outline-none focus:border-indigo-500">
                            <option value="Book" {% if product.category == 'Book' %}selected{% endif %}>Book</option>
                            <option value="Notebook" {% if product.category == 'Notebook' %}selected{% endif %}>Notebook</option>
                            <option value="Stationery" {% if product.category == 'Stationery' %}selected{% endif %}>Stationery</option>
                            <option value="Uniform" {% if product.category == 'Uniform' %}selected{% endif %}>Uniform</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Barcode Entity</label>
                        <input type="text" id="prodBarcode" value="{{ product.barcode or '' }}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs font-mono focus:outline-none focus:border-indigo-500" placeholder="Optional Serial">
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Product Title Name *</label>
                    <input type="text" id="prodName" value="{{ product.name }}" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs font-bold focus:outline-none focus:border-indigo-500">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div id="classFieldWrapper">
                        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Target Student Class</label>
                        <input type="text" id="prodClass" value="{{ product.student_class or '' }}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:outline-none focus:border-indigo-500" placeholder="e.g. 10th">
                    </div>
                    <div id="subjectFieldWrapper">
                        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Subject Variant</label>
                        <input type="text" id="prodSubject" value="{{ product.subject or '' }}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:outline-none focus:border-indigo-500" placeholder="e.g. Physics">
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Attributes / Variations</label>
                    <input type="text" id="prodVariation" value="{{ product.variation or '' }}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:outline-none focus:border-indigo-500" placeholder="Size, Color configurations">
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Cost Price *</label>
                        <input type="number" step="0.01" id="prodPPrice" value="{{ product.purchase_price }}" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs font-bold focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1">Retail Price *</label>
                        <input type="number" step="0.01" id="prodSPrice" value="{{ product.selling_price }}" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs font-bold focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label id="stockLabel" class="block text-[10px] font-black uppercase tracking-wider text-indigo-600 mb-1">Add New Stock *</label>
                        <input type="number" id="prodStock" required class="w-full bg-indigo-50/50 border border-indigo-200 rounded-xl px-3 py-2 text-xs font-black text-indigo-700 focus:outline-none focus:border-indigo-500" placeholder="+ Delta">
                    </div>
                </div>

                <div class="border-t border-slate-100 pt-4 mt-6 flex justify-end gap-2">
                    <button type="button" onclick="closeProductModal()" class="bg-slate-100 text-slate-600 px-4 py-2 rounded-xl text-xs font-bold uppercase hover:bg-slate-200 transition">Cancel</button>
                    <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-xl text-xs font-black uppercase shadow-md hover:bg-indigo-700 transition">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <!-- INTERACTIVE ENGINE CONTROLLERS -->
    <script>
        let creditFilterActive = false;

        function toggleCreditFilter() {
            const rows = document.querySelectorAll('.sales-row');
            const alertBar = document.getElementById('filterAlertBar');
            creditFilterActive = !creditFilterActive;

            if (creditFilterActive) {
                alertBar.classList.remove('hidden');
                rows.forEach(row => {
                    const status = row.getAttribute('data-status').trim().toLowerCase();
                    if (status === 'paid') {
                        row.classList.add('hidden');
                    } else {
                        row.classList.remove('hidden');
                    }
                });
            } else {
                alertBar.classList.add('hidden');
                rows.forEach(row => row.classList.remove('hidden'));
            }
        }

        function openProductModal(mode) {
            document.getElementById("formMode").value = mode;
            document.getElementById("productModal").classList.remove("hidden");
            adaptFormToCategory();
        }

        function closeProductModal() {
            document.getElementById("productModal").classList.add("hidden");
        }

        function adaptFormToCategory() {
            const cat = document.getElementById("prodCat").value;
            const classWrapper = document.getElementById("classFieldWrapper");
            const subWrapper = document.getElementById("subjectFieldWrapper");

            if (cat === "Book") {
                classWrapper.classList.remove("hidden");
                subWrapper.classList.remove("hidden");
            } else if (cat === "Notebook") {
                classWrapper.classList.remove("hidden");
                subWrapper.classList.add("hidden");
            } else {
                classWrapper.classList.add("hidden");
                subWrapper.classList.add("hidden");
            }
        }

        async function handleFormSubmission(e) {
            e.preventDefault();
            const formData = new FormData();
            formData.append("mode", document.getElementById("formMode").value);
            formData.append("prod_id", document.getElementById("formProdId").value);
            formData.append("cat", document.getElementById("prodCat").value);
            formData.append("name", document.getElementById("prodName").value);
            formData.append("s_class", document.getElementById("prodClass").value);
            formData.append("sub", document.getElementById("prodSubject").value);
            formData.append("variation", document.getElementById("prodVariation").value);
            formData.append("barcode", document.getElementById("prodBarcode").value);
            formData.append("p_price", document.getElementById("prodPPrice").value);
            formData.append("s_price", document.getElementById("prodSPrice").value);
            formData.append("stock", document.getElementById("prodStock").value);
            formData.append("force_new", "false");

            try {
                const response = await fetch('/api/products/smart-add', { method: 'POST', body: formData });
                const result = await response.json();
                if (result.status === "success") {
                    closeProductModal();
                    window.location.reload();
                } else {
                    alert("Error: " + result.message);
                }
            } catch (error) {
                alert("Network operational issue encountered.");
            }
        }
    </script>
</body>
</html>
